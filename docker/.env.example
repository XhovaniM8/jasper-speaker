# Copy to docker/.env and fill in values.
# NEVER commit docker/.env — it is in .gitignore

# Timezone (used by all containers)
TZ=America/New_York

# ── Music Assistant ──────────────────────────────────────────────
# Spotify credentials are configured inside the MA web UI (port 8095),
# not via env vars. No Spotify keys needed here.

# ── Home Assistant ───────────────────────────────────────────────
# Anthropic API key — added inside HA via Settings → Integrations → Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Runtime tokens (auto-generated, do not set manually) ─────────
# .ha_token   — HA long-lived token (generate in HA: Profile → Long-Lived Access Tokens)
# .ma_token   — MA long-lived token (auto-created by scripts/health.sh on first run)
# Both files live in the repo root and are git-ignored.
