# Copy to docker/.env and fill in real values.
# NEVER commit docker/.env — it is in .gitignore

# Timezone
TZ=America/New_York

# OpenAI API key (used by Home Assistant conversation agent)
OPENAI_API_KEY=sk-...

# Home Assistant long-lived access token (for CamillaDSP HA integration)
# Generate in HA: Profile → Long-Lived Access Tokens
HA_TOKEN=

# Optional: Spotify app credentials (if using Spotify Connect via MA)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
